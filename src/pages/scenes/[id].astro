---
// --- IMPORTS & CONFIG ---
export const prerender = true;
import Layout from '../../layouts/Layout.astro';
import { pb } from '../../../backend/backend.mjs';

// --- ROUTING & DATA FETCHING ---
export async function getStaticPaths() {
  const scenes = await pb.collection('scene').getFullList({
    expand: 'field', 
  });
  
  return scenes.map((scene) => ({
    params: { id: scene.id },
    props: { scene },
  }));
}

const { scene } = Astro.props;

// --- DATA PROCESSING ---
const pbUrl = "http://127.0.0.1:8090/api/files/";
const imageUrl = `${pbUrl}${scene.collectionId}/${scene.id}/${scene.photo}`;
const artistesLiees = scene.expand?.field || [];
---

<Layout title={`${scene.nom} | Flying Tap Fest`}>
  <main class="bg-[#243B55] min-h-screen pt-32 pb-20 px-6 md:px-12">
    <div class="max-w-6xl mx-auto">
      
      <a href="/scenes" class="text-[#E9DCC9] uppercase tracking-widest text-sm mb-12 inline-block hover:underline font-sans">
        ← Retour aux scènes
      </a>

      <div class="grid grid-cols-1 lg:grid-cols-2 gap-16 items-start">
        
        <div class="relative group lg:sticky lg:top-32">
          <div class="absolute -inset-4 border-2 border-[#9EB27C]/30 rounded-lg transform -rotate-2 pointer-events-none transition-transform group-hover:rotate-0 duration-500 z-0"></div>
           
          <div class="relative z-10 rounded-2xl overflow-hidden border-4 border-[#E9DCC9] shadow-2xl bg-slate-900 aspect-video lg:aspect-[4/5]">
            <img 
              src={imageUrl} 
              alt={scene.nom} 
              class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-105" 
            />
          </div>
        </div>

        <div class="flex flex-col gap-10">
          
          <div>
            <h1 class="text-[#E9DCC9] text-6xl md:text-8xl leading-tight mb-4" style="font-family: 'Pacifico', cursive;">
              {scene.nom}
            </h1>
            <div class="flex items-center gap-3">
              <span class="w-12 h-[2px] bg-[#9EB27C]"></span>
              <p class="text-[#9EB27C] text-xl uppercase tracking-[0.3em] font-bold">
                {scene.localisation}
              </p>
            </div>
          </div>

          <div class="text-[#E9DCC9]/90 font-sans text-lg leading-relaxed space-y-4">
            <div set:html={scene.description} />
          </div>

          <div class="mt-8 border-t border-[#E9DCC9]/20 pt-10">
            <h2 class="text-[#E9DCC9] text-3xl mb-10" style="font-family: 'Pacifico', cursive;">Au programme sur cette scène</h2>
            
            {artistesLiees.length > 0 ? (
              <div class="grid grid-cols-2 sm:grid-cols-3 gap-8">
                {artistesLiees.map((artiste) => (
                  <a href={`/artistes/${artiste.id}`} class="group flex flex-col items-center gap-4 text-center">
                    <div class="w-24 h-24 md:w-32 md:h-32 rounded-full overflow-hidden border-2 border-[#E9DCC9] shadow-lg transition-all group-hover:scale-110 group-hover:border-[#9EB27C]">
                      <img 
                        src={`${pbUrl}${artiste.collectionId}/${artiste.id}/${artiste.PhotoPrincipale}`} 
                        alt={artiste.nom} 
                        class="w-full h-full object-cover"
                      />
                    </div>
                    <span class="text-[#E9DCC9] font-bold text-sm uppercase tracking-wider group-hover:text-[#9EB27C] transition-colors leading-tight">
                      {artiste.nom}
                    </span>
                  </a>
                ))}
              </div>
            ) : (
              <p class="text-[#E9DCC9]/50 italic">La programmation arrive bientôt !</p>
            )}
          </div>

        </div>
      </div>
    </div>
  </main>
</Layout>