---
// --- IMPORTS & CONFIG ---
export const prerender = true;
import Layout from '../../layouts/Layout.astro';
import { getArtistesSortedByName } from '../../../backend/backend.mjs';

// --- ROUTING & DATA FETCHING ---
export async function getStaticPaths() {
  const artistes = await getArtistesSortedByName();
  return artistes.map((artiste) => ({
    params: { id: artiste.id },
    props: { artiste }, 
  }));
}

const { artiste } = Astro.props;

if (!artiste) {
  return Astro.redirect('/404');
}

// --- DATA PROCESSING ---
const allImages = [
  artiste.PhotoPrincipale,
  ...(artiste.GaleriePhoto || [])
].filter(Boolean);

const baseUrl = `http://127.0.0.1:8090/api/files/${artiste.collectionId}/${artiste.id}/`;
const nomScene = artiste.expand?.scene?.nom || artiste.scene || "Scène 1";
const bioHtml = artiste.description || artiste.Description;
---

<Layout title={`${artiste.nom} | Flying Tap Fest`}>
  <main class="bg-[#243B55] min-h-screen pt-32 pb-20 px-6 md:px-12">
    <div class="max-w-6xl mx-auto">
      
      <a href="/" class="text-[#E9DCC9] uppercase tracking-widest text-sm mb-12 inline-block hover:underline font-sans">
        ← Retour à l'accueil
      </a>

      <div class="grid grid-cols-1 md:grid-cols-2 gap-12 md:gap-24 items-start">
        
        <div class="relative group md:sticky md:top-32">
          <div class="absolute -inset-4 border-2 border-[#E9DCC9]/30 rounded-lg transform rotate-3 pointer-events-none transition-transform group-hover:rotate-0 duration-500"></div>
          
          <div class="relative w-full aspect-[4/5] shadow-2xl border-4 border-[#E9DCC9] rounded-md overflow-hidden bg-slate-900">
            <div id="carousel-track" class="flex h-full transition-transform duration-500 ease-in-out">
              {allImages.map((img, index) => (
                <img 
                  src={`${baseUrl}${img}`} 
                  alt={`${artiste.nom} - photo ${index + 1}`} 
                  class="min-w-full h-full object-cover cursor-pointer"
                  data-carousel-item
                />
              ))}
            </div>

            {allImages.length > 1 && (
              <>
                <div class="absolute inset-y-0 left-0 right-0 flex items-center justify-between px-4 opacity-0 group-hover:opacity-100 transition-opacity pointer-events-none z-10">
                  <button id="prev" class="p-3 rounded-full bg-[#243B55]/80 backdrop-blur-sm text-[#E9DCC9] pointer-events-auto hover:bg-[#E9DCC9] hover:text-[#243B55] transition-all transform hover:scale-110 shadow-lg" aria-label="Image précédente">
                    <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="m15 18-6-6 6-6"/></svg>
                  </button>
                  <button id="next" class="p-3 rounded-full bg-[#243B55]/80 backdrop-blur-sm text-[#E9DCC9] pointer-events-auto hover:bg-[#E9DCC9] hover:text-[#243B55] transition-all transform hover:scale-110 shadow-lg" aria-label="Image suivante">
                    <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="m9 18 6-6-6-6"/></svg>
                  </button>
                </div>
                
                <div class="absolute bottom-6 left-1/2 -translate-x-1/2 flex gap-3 z-10 bg-black/30 px-3 py-2 rounded-full backdrop-blur-sm">
                  {allImages.map((_, i) => (
                    <div class="w-2.5 h-2.5 rounded-full bg-white/50 transition-all duration-300" data-dot={i}></div>
                  ))}
                </div>
              </>
            )}
          </div>
        </div>

        <div class="flex flex-col gap-10">
          <h1 class="text-[#E9DCC9] text-6xl md:text-8xl leading-tight" style="font-family: 'Pacifico', cursive;">
            {artiste.nom}
          </h1>

          <div class="space-y-8">
            <div 
              class="text-white text-lg md:text-xl font-sans leading-relaxed font-light opacity-90 description-content" 
              set:html={bioHtml} 
            />

            <div class="bg-[#E9DCC9]/10 p-8 rounded-md border border-[#E9DCC9]/20">
              <p class="text-[#E9DCC9] font-bold uppercase tracking-widest text-xs mb-3">Programmation</p>
              <p class="text-white text-xl font-sans">
                {artiste.jour || "Samedi 6 Juin"} — {nomScene}
              </p>
            </div>
          </div>

          <a href="/billetterie" class="bg-[#9EB27C] text-[#243B55] text-xl font-bold py-4 px-10 rounded-md self-start hover:scale-105 transition-transform shadow-lg uppercase tracking-widest text-center mt-4">
            Réserver mon pass
          </a>
        </div>

      </div>
    </div>
  </main>
</Layout>

<script>
  const track = document.getElementById('carousel-track');
  const items = document.querySelectorAll('[data-carousel-item]');
  const prevBtn = document.getElementById('prev');
  const nextBtn = document.getElementById('next');
  const dots = document.querySelectorAll('[data-dot]');

  let currentIndex = 0;
  const total = items.length;

  function updateCarousel(index) {
    if (!track) return;
    currentIndex = index;
    track.style.transform = `translateX(-${currentIndex * 100}%)`;
    
    dots.forEach((dot, i) => {
      dot.style.backgroundColor = i === currentIndex ? '#E9DCC9' : 'rgba(255,255,255,0.4)';
      dot.style.width = i === currentIndex ? '1.5rem' : '0.625rem';
    });
  }

  items.forEach((item) => {
    item.addEventListener('click', () => {
      const nextIndex = (currentIndex + 1) % total;
      updateCarousel(nextIndex);
    });
  });

  nextBtn?.addEventListener('click', (e) => {
    e.stopPropagation();
    updateCarousel((currentIndex + 1) % total);
  });

  prevBtn?.addEventListener('click', (e) => {
    e.stopPropagation();
    updateCarousel((currentIndex - 1 + total) % total);
  });

  if (total > 0) {
    updateCarousel(0);
  }
</script>

<style is:global>
  .description-content p {
    margin-bottom: 1.5rem;
  }
  .description-content strong {
    color: #E9DCC9;
    font-weight: 700;
  }
</style>