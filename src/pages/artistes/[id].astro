---
// src/pages/artistes/[id].astro
export const prerender = true;

import Layout from '../../layouts/Layout.astro';
import { getArtistesSortedByName } from '../../../backend/backend.mjs';

export async function getStaticPaths() {
  const artistes = await getArtistesSortedByName();
  return artistes.map((artiste) => ({
    params: { id: artiste.id },
    props: { artiste }, 
  }));
}

const { artiste } = Astro.props;

if (!artiste) {
  return Astro.redirect('/404');
}

// 1. Préparation de la liste d'images
const allImages = [
  artiste.PhotoPrincipale,
  ...(artiste.GaleriePhoto || [])
].filter(Boolean);

const baseUrl = `http://127.0.0.1:8090/api/files/${artiste.collectionId}/${artiste.id}/`;

// 2. CORRECTION DE LA SCÈNE
// On cherche le nom dans expand. Si ce n'est pas une relation mais un texte simple, on utilise artiste.scene
const nomScene = artiste.expand?.scene?.nom || artiste.scene || "Scène 1";

// Bio
const bioHtml = artiste.description || artiste.Description;
---

<Layout title={`${artiste.nom} | Flying Tap Fest`}>
  <main class="bg-[#243B55] min-h-screen pt-32 pb-20 px-6 md:px-12">
    
    <div class="max-w-6xl mx-auto">
      
      <a href="/" class="text-[#E9DCC9] uppercase tracking-widest text-sm mb-12 inline-block hover:underline font-sans">
        ← Retour à l'accueil
      </a>

      <div class="grid grid-cols-1 md:grid-cols-2 gap-12 md:gap-24 items-start">
        
        <div class="relative group sticky top-40 overflow-hidden rounded-lg">
          <div class="absolute -inset-4 border-2 border-[#E9DCC9]/20 rounded-lg transform rotate-3 pointer-events-none"></div>
          
          <div class="relative w-full aspect-[4/5] shadow-2xl border-4 border-[#E9DCC9] rounded-md overflow-hidden bg-slate-900">
            <div id="carousel-track" class="flex h-full transition-transform duration-500 ease-out">
              {allImages.map((img, index) => (
                <img 
                  src={`${baseUrl}${img}`} 
                  alt={`${artiste.nom} - photo ${index + 1}`} 
                  class="w-full h-full object-cover flex-shrink-0 cursor-pointer"
                  data-carousel-item
                />
              ))}
            </div>

            {allImages.length > 1 && (
              <div class="absolute inset-0 flex items-center justify-between px-4 opacity-0 group-hover:opacity-100 transition-opacity pointer-events-none">
                <button id="prev" class="p-2 rounded-full bg-black/50 text-white pointer-events-auto hover:bg-[#E9DCC9] hover:text-[#243B55] transition-colors">
                  <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m15 18-6-6 6-6"/></svg>
                </button>
                <button id="next" class="p-2 rounded-full bg-black/50 text-white pointer-events-auto hover:bg-[#E9DCC9] hover:text-[#243B55] transition-colors">
                  <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m9 18 6-6-6-6"/></svg>
                </button>
              </div>
              
              <div class="absolute bottom-4 left-1/2 -translate-x-1/2 flex gap-2">
                {allImages.map((_, i) => (
                   <div class="w-2 h-2 rounded-full bg-white/50" data-dot={i}></div>
                ))}
              </div>
            )}
          </div>
        </div>

        <div class="flex flex-col gap-10">
          <h1 class="text-[#E9DCC9] text-6xl md:text-8xl leading-tight" style="font-family: 'Pacifico', cursive;">
            {artiste.nom}
          </h1>

          <div class="space-y-8">
             <div 
                class="text-white text-lg md:text-xl font-sans leading-relaxed font-light opacity-90 description-content" 
                set:html={bioHtml} 
             />

             <div class="bg-[#E9DCC9]/10 p-8 rounded-md border border-[#E9DCC9]/20">
                <p class="text-[#E9DCC9] font-bold uppercase tracking-widest text-xs mb-3">Programmation</p>
                <p class="text-white text-xl font-sans">
                  {artiste.jour || "Samedi 6 Juin"} — {nomScene}
                </p>
             </div>
          </div>

          <a href="/404.astro" class="bg-[#9EB27C] text-[#243B55] text-xl font-bold py-4 px-10 rounded-md self-start hover:scale-105 transition-transform shadow-lg uppercase tracking-widest text-center mt-4">
            Réserver mon pass
          </a>
        </div>
      </div>
    </div>
  </main>
</Layout>

<script>
  // Logique du Carousel
  const track = document.getElementById('carousel-track');
  const items = document.querySelectorAll('[data-carousel-item]');
  const prevBtn = document.getElementById('prev');
  const nextBtn = document.getElementById('next');
  const dots = document.querySelectorAll('[data-dot]');

  let currentIndex = 0;
  const total = items.length;

  function updateCarousel(index) {
    if (!track) return;
    currentIndex = index;
    track.style.transform = `translateX(-${currentIndex * 100}%)`;
    
    // Update dots
    dots.forEach((dot, i) => {
      dot.style.backgroundColor = i === currentIndex ? '#E9DCC9' : 'rgba(255,255,255,0.5)';
      dot.style.width = i === currentIndex ? '1.5rem' : '0.5rem';
      dot.style.transition = 'all 0.3s ease';
    });
  }

  // Clic sur l'image pour passer à la suivante
  items.forEach((item, i) => {
    item.addEventListener('click', () => {
      const nextIndex = (currentIndex + 1) % total;
      updateCarousel(nextIndex);
    });
  });

  // Boutons Next/Prev
  nextBtn?.addEventListener('click', (e) => {
    e.stopPropagation();
    updateCarousel((currentIndex + 1) % total);
  });

  prevBtn?.addEventListener('click', (e) => {
    e.stopPropagation();
    updateCarousel((currentIndex - 1 + total) % total);
  });

  // Initialisation
  updateCarousel(0);
</script>

<style is:global>
  .description-content p {
    margin-bottom: 1.5rem;
  }
  .description-content strong {
    color: #E9DCC9;
    font-weight: 700;
  }
  /* Cacher la scrollbar si nécessaire */
  #carousel-track {
    scrollbar-width: none;
    -ms-overflow-style: none;
  }
  #carousel-track::-webkit-scrollbar {
    display: none;
  }
</style>