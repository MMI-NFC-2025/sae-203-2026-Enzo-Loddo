---
// src/pages/contact.astro
import Layout from '../layouts/Layout.astro';
import Header from '../assets/components/Header.astro'; 
---

<Layout title="Contact | Flying Tap Fest">
  <main class="bg-[#243B55] min-h-screen flex flex-col pt-32 pb-20 px-6 md:px-12 m-0 border-t-0">
    
    <div class="max-w-5xl mx-auto w-full">
      
      <h1 class="text-[#E9DCC9] text-6xl md:text-8xl text-center mb-20" style="font-family: 'Pacifico', cursive;">
        Contact
      </h1>

      <form class="flex flex-col gap-8 mb-24">
        
        <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
          <div class="flex flex-col gap-3">
            <label class="text-[#E9DCC9] text-xl font-sans" for="prenom">Prénom</label>
            <input 
              type="text" 
              id="prenom" 
              class="bg-[#E9DCC9] border-2 border-[#E9DCC9] text-[#243B55] rounded-md h-14 px-5 outline-none font-semibold text-lg w-full"
              required
            />
          </div>

          <div class="flex flex-col gap-3">
            <label class="text-[#E9DCC9] text-xl font-sans" for="nom">Nom</label>
            <input 
              type="text" 
              id="nom" 
              class="bg-[#E9DCC9] border-2 border-[#E9DCC9] text-[#243B55] rounded-md h-14 px-5 outline-none font-semibold text-lg w-full"
              required
            />
          </div>
        </div>

        <div class="flex flex-col gap-3">
          <label class="text-[#E9DCC9] text-xl font-sans" for="email">E-Mail</label>
          <input 
            type="email" 
            id="email" 
            class="bg-[#E9DCC9] border-2 border-[#E9DCC9] text-[#243B55] rounded-md h-14 px-5 outline-none font-semibold text-lg w-full"
            required
          />
        </div>

        <div class="flex flex-col gap-3">
          <label class="text-[#E9DCC9] text-xl font-sans" for="message">Message</label>
          <textarea 
            id="message" 
            rows="8" 
            class="bg-[#E9DCC9] border-2 border-[#E9DCC9] text-[#243B55] rounded-md p-5 outline-none font-semibold text-lg w-full"
            required
          ></textarea>
        </div>

        <div class="pt-4">
          <button 
            type="submit" 
            class="bg-[#9EB27C] text-[#243B55] text-2xl font-bold py-4 px-16 rounded-md hover:bg-[#8da36d] transition-all shadow-lg uppercase tracking-widest"
          >
            Envoyer
          </button>
        </div>
      </form>

      <div class="flex flex-col md:flex-row justify-between items-start gap-16 md:gap-0 border-t border-[#E9DCC9]/20 pt-16">
        
        <div class="flex-1">
          <h2 class="text-[#E9DCC9] text-5xl mb-8" style="font-family: 'Pacifico', cursive;">
            Coordonnées
          </h2>
          <div class="text-[#E9DCC9] text-xl font-sans space-y-3 font-light opacity-90">
            <p class="hover:text-white transition-colors">contact@flyingtapfest.fr</p>
            <p>03 84 90 90 90</p>
            <p>6 place de la Révolution Française,</p>
            <p>90000 Belfort</p>
          </div>
        </div>

        <div class="flex-1 md:text-right">
          <h2 class="text-[#E9DCC9] text-5xl mb-10" style="font-family: 'Pacifico', cursive;">
            Réseaux sociaux
          </h2>
          <div class="flex gap-10 md:justify-end">
            <a href="#" class="text-[#E9DCC9] hover:scale-125 transition-transform duration-300">
               <svg class="w-12 h-12" fill="currentColor" viewBox="0 0 24 24"><path d="M22.675 0h-21.35C.597 0 0 .597 0 1.325v21.351C0 23.403.597 24 1.325 24H12.82v-9.294H9.692v-3.622h3.128V8.413c0-3.1 1.893-4.788 4.659-4.788 1.325 0 2.463.099 2.795.143v3.24l-1.918.001c-1.504 0-1.795.715-1.795 1.763v2.313h3.587l-.467 3.622h-3.12V24h6.116c.73 0 1.323-.597 1.323-1.324V1.325C24 .597 23.403 0 22.675 0z"/></svg>
            </a>
            <a href="#" class="text-[#E9DCC9] hover:scale-125 transition-transform duration-300">
               <svg class="w-12 h-12" fill="currentColor" viewBox="0 0 24 24"><path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zM12 0C8.741 0 8.333.014 7.053.072 2.695.272.273 2.69.073 7.052.014 8.333 0 8.741 0 12c0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98 1.281.058 1.689.072 4.948.072 3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98C15.668.014 15.259 0 12 0zm0 5.838a6.162 6.162 0 100 12.324 6.162 6.162 0 000-12.324zM12 16a4 4 0 110-8 4 4 0 010 8zm6.406-11.845a1.44 1.44 0 100 2.881 1.44 1.44 0 000-2.881z"/></svg>
            </a>
            <a href="#" class="text-[#E9DCC9] hover:scale-125 transition-transform duration-300">
               <svg class="w-12 h-12" fill="currentColor" viewBox="0 0 24 24"><path d="M23.954 4.569c-.885.389-1.83.654-2.825.775 1.014-.611 1.794-1.574 2.163-2.723-.951.555-2.005.959-3.127 1.184-.896-.959-2.173-1.559-3.591-1.559-2.717 0-4.92 2.203-4.92 4.917 0 .39.045.765.127 1.124C7.691 8.094 4.066 6.13 1.64 3.161c-.427.722-.666 1.561-.666 2.475 0 1.71.87 3.213 2.188 4.096-.807-.026-1.566-.248-2.228-.616v.061c0 2.385 1.693 4.374 3.946 4.827-.413.111-.849.171-1.296.171-.314 0-.615-.03-.916-.086.631 1.953 2.445 3.377 4.604 3.417-1.68 1.319-3.809 2.105-6.102 2.105-.39 0-.779-.023-1.17-.067 2.189 1.394 4.768 2.209 7.557 2.209 9.054 0 13.999-7.496 13.999-13.986 0-.209 0-.42-.015-.63.961-.689 1.8-1.56 2.46-2.548l-.047-.02z"/></svg>
            </a>
          </div>
        </div>

      </div>
    </div>
  </main>

  <footer class="bg-[#E9DCC9] py-16 px-6 border-t border-[#243B55]/10">
    <div class="max-w-6xl mx-auto flex flex-col md:flex-row justify-center items-center gap-16 md:gap-32">
       <img src="/imagefooter1.webp" alt="Fédération Française de Danse" class="h-20 w-auto object-contain" />
       <img src="/imagefooter2.webp" alt="Territoire de Belfort" class="h-16 w-auto object-contain" />
       <img src="/logodark.webp" alt="Flying Tap Fest" class="h-18 w-auto" />
    </div>
  </footer>
</Layout>