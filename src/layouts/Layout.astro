---
// src/layouts/Layout.astro
import Header from '../assets/components/Header.astro';
import '../styles/global.css'; // Assure-toi que ce chemin correspond à ton fichier css global

interface Props {
	title: string;
}

const { title } = Astro.props;
---

<!doctype html>
<html lang="fr" class="scroll-smooth">
	<head>
		<meta charset="UTF-8" />
		<meta name="description" content="Festival de musique - SAE 203" />
		<meta name="viewport" content="width=device-width" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<meta name="generator" content={Astro.generator} />
		<title>{title}</title>
		<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Lato:wght@300;400;700&family=Pacifico&display=swap" rel="stylesheet">

<style is:global>
  :root {
    --font-title: 'Pacifico', cursive;
    --font-text: 'Lato', sans-serif;
  }

  /* Tous les titres utilisent Pacifico */
  h1, h2, h3, h4, .font-title {
    font-family: var(--font-title) !important;
  }

  /* Les liens du menu de navigation utilisent aussi Pacifico */
  #mobile-menu nav a {
    font-family: var(--font-title);
  }

  /* Tout le reste du texte utilise Lato */
  body, p, span, input, .font-text {
    font-family: var(--font-text);
  }
</style>
	</head>
	
	<body class="bg-[#0b0b10] text-gray-100 font-sans min-h-screen flex flex-col">
		
		<Header />
		
		<main class="flex-grow">
			<slot />
		</main>

		</body>
</html>